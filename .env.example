# This plugin uses Claude Code MCPs — tokens are NOT stored here.
# Configure your MCPs in ~/.claude/mcp.json:
#
# {
#   "mcpServers": {
#     "slack": {
#       "command": "npx",
#       "args": ["-y", "mcp-server-slack"],
#       "env": { "SLACK_BOT_TOKEN": "xoxb-..." }
#     },
#     "shortcut": {
#       "command": "npx",
#       "args": ["-y", "mcp-server-shortcut"],
#       "env": { "SHORTCUT_API_TOKEN": "sct_..." }
#     }
#   }
# }
#
# Legacy CLI (index.js) only — not needed for the /daily-compare plugin:
# SLACK_TOKEN=xoxb-...
# SHORTCUT_TOKEN=sct_...
